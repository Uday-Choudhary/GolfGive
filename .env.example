# ── Frontend (Vite — VITE_ prefix required) ──────────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Express Backend ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT
JWT_SECRET=super-secret-jwt-access-key-change-in-production
JWT_REFRESH_SECRET=super-secret-jwt-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_MONTHLY_PRICE_ID=price_monthly_xxxxx
STRIPE_YEARLY_PRICE_ID=price_yearly_xxxxx

# Supabase (server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourplatform.com

# Server
PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
